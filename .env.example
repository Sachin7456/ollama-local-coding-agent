# qwen-harness configuration — copy this file to ".env" and fill in as needed.
# ALL of these are OPTIONAL. The harness needs NO secrets to run locally.
# Real environment variables take precedence over .env. Never commit a real .env.

# Ollama server URL (default: http://127.0.0.1:11434)
OLLAMA_BASE_URL=

# Default model tag to use (default: qwen2.5-coder:7b)
HARNESS_MODEL=

# Where model definitions come from: "builtin" (default, fast) or "file"
QWEN_HARNESS_MODEL_SOURCE=

# Path to your models JSON when QWEN_HARNESS_MODEL_SOURCE=file (default: ./models.json)
QWEN_HARNESS_MODELS_FILE=

# Directory for sessions + long-term memory (default: ~/.qwen-harness)
QWEN_HARNESS_DIR=

# --- API keys for external "compat" connections (used by a models.json connection's apiKeyEnv) ---
# Each compat connection names its OWN env var; put the matching key here (only in your local .env, never in code).
# (External /v1 (compat) providers land in the next release; until then a compat connection errors clearly.)
# GROQ_WORK=
# GROQ_PERSONAL=
# OPENROUTER_API_KEY=
